<!DOCTYPE html>
<html lang="hi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>कैरम बोर्ड गेम</title>
    <style>
        body {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            background-color: #2c3e50;
            margin: 0;
            font-family: Arial, sans-serif;
        }

        /* मुख्य कैरम बोर्ड (लकड़ी का बॉर्डर) */
        .carrom-board {
            width: 500px;
            height: 500px;
            background-color: #f3d598; /* प्लाईवुड का रंग */
            border: 25px solid #5c3a21; /* लकड़ी का बॉर्डर */
            box-shadow: 0px 10px 30px rgba(0,0,0,0.5);
            position: relative;
            border-radius: 4px;
        }

        /* चारों कोनों के होल्स (Pockets) */
        .pocket {
            width: 45px;
            height: 45px;
            background-color: #111;
            border-radius: 50%;
            position: absolute;
            box-shadow: inset 0px 5px 10px rgba(0,0,0,0.8);
        }
        .top-left { top: 5px; left: 5px; }
        .top-right { top: 5px; right: 5px; }
        .bottom-left { bottom: 5px; left: 5px; }
        .bottom-right { bottom: 5px; right: 5px; }

        /* बेसलाइन (जहाँ स्ट्राइकर रखा जाता है) */
        .baseline {
            position: absolute;
            border: 2px solid #b22222;
            background-color: transparent;
        }
        .baseline.bottom {
            width: 320px;
            height: 25px;
            bottom: 60px;
            left: 90px;
            border-radius: 5px;
        }

        /* सेंटर सर्कल (बीच का गोला) */
        .center-circle {
            width: 80px;
            height: 80px;
            border: 3px dashed #b22222;
            border-radius: 50%;
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* लाल गोटी (Queen) */
        .queen {
            width: 20px;
            height: 20px;
            background-color: #ff0000; /* लाल रंग */
            border-radius: 50%;
            border: 2px solid #fff;
            box-shadow: 2px 2px 5px rgba(0,0,0,0.3);
        }

        /* स्ट्राइकर (अभी इसे सिर्फ बेसलाइन पर दिखाया है) */
